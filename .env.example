# Telegram
TELEGRAM_BOT_TOKEN=             # Token from @BotFather
TELEGRAM_WEBHOOK_SECRET=        # Random 40+ char string — used as webhook secret header
TELEGRAM_CHAT_IDS=              # Comma-separated list of your personal chat_id(s) for cron delivery
BOT_PASSWORD=                   # Password new users DM to gain access

# Database
DATABASE_URL=                   # Neon connection string (postgresql://...)

# OpenRouter
OPENROUTER_API_KEY=             # From openrouter.ai dashboard
DEFAULT_MODEL=google/gemini-flash-1.5
DEEPDIVE_MODEL=anthropic/claude-3-5-haiku-20241022
DEEPDIVE_DAY=4                  # 0=Mon … 6=Sun; 4=Friday
EMBEDDING_MODEL=openai/text-embedding-3-small

# Cron security
CRON_SECRET=                    # Random secret appended to cron trigger URLs

# Ingestion config
ARXIV_CATEGORIES=q-fin.PM,q-fin.ST,q-fin.TR,q-fin.MF,q-fin.RM,cs.CE,stat.ML,stat.AP
ARXIV_MAX_RESULTS=50            # Papers fetched per run
ALLOWED_TOPICS=factor model,momentum,volatility forecasting,order book,regime detection,mean reversion,cross-sectional,alpha decay,market microstructure,alternative data,options pricing,liquidity,machine learning,neural network,deep learning,reinforcement learning,natural language processing,sentiment

# Filter thresholds
RELEVANCE_THRESHOLD=0.65        # Min embedding similarity vs seed corpus
QUALITY_GATE_MIN=13             # Min combined novelty + feasibility score
DEDUP_SIMILARITY_MAX=0.80       # Max similarity to any previously sent idea

# Delivery config
MAX_IDEAS_PER_DAY=2             # Max ideas sent per daily deliver run
